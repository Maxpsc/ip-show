{
  "manifest_version": 3,
  "name": "IP Show",
  "version": "1.0.0",
  "description": "全方位检测您的IP地址 - 查看国内、国外及谷歌访问IP",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/ip-icon.png",
      "48": "icons/ip-icon.png",
      "128": "icons/ip-icon.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://ip-api.com/*",
    "https://api.ip.sb/*",
    "https://whois.pconline.com.cn/*",
    "https://www.ip111.cn/*",
    "https://ip111.cn/*"
  ]
}
